name: Scope Check
on:
  pull_request:
    types: [opened, synchronize]

permissions:
  contents: read
  pull-requests: write
  issues: write

jobs:
  check:
    runs-on: ubuntu-latest
    steps:
      - uses: actions/checkout@v4
        with:
          fetch-depth: 0

      - name: Get changed files
        id: changed
        run: |
          echo "files=$(git diff --name-only --diff-filter=ACMRT ${{ github.event.pull_request.base.sha }} ${{ github.event.pull_request.head.sha }} | jq -R -s -c 'split(\"\n\")[:-1]')" >> "$GITHUB_OUTPUT"

      - name: Check scope violations
        id: check
        run: |
          CHANGED_FILES='${{ steps.changed.outputs.files }}'
          if [ "$CHANGED_FILES" = "[]" ] || [ -z "$CHANGED_FILES" ]; then
            echo "No changed files to check."
            echo "violations=[]" >> "$GITHUB_OUTPUT"
            exit 0
          fi

          # Read scope manifests
          VIOLATIONS="[]"
          if [ -d ".plansync/scopes" ]; then
            for manifest in .plansync/scopes/*.json; do
              SCOPE_GLOBS=$(node -e "const m = require('./$manifest'); console.log(JSON.stringify(m.scope))")
              OUT_OF_SCOPE=$(node -e "
                const { minimatch } = require('minimatch');
                const files = $CHANGED_FILES;
                const globs = $SCOPE_GLOBS;
                const out = files.filter(f => !globs.some(g => minimatch(f, g, { dot: true })));
                console.log(JSON.stringify(out));
              ")
              if [ "$OUT_OF_SCOPE" != "[]" ] && [ -n "$OUT_OF_SCOPE" ]; then
                TASK_ID=$(node -e "console.log(require('./$manifest').taskId)")
                VIOLATIONS=$(node -e "
                  const v = $VIOLATIONS;
                  v.push({ task: '$TASK_ID', files: $OUT_OF_SCOPE });
                  console.log(JSON.stringify(v));
                ")
              fi
            done
          fi

          echo "violations=$VIOLATIONS" >> "$GITHUB_OUTPUT"
          echo "Violations found: $(echo $VIOLATIONS | node -e "process.stdin.on('data', d => { const v = JSON.parse(d); console.log(v.length); })")"

      - name: Comment on PR
        if: steps.check.outputs.violations != '[]'
        uses: actions/github-script@v7
        with:
          script: |
            const violations = JSON.parse(process.env.VIOLATIONS || '${{ steps.check.outputs.violations }}');
            let body = '## ⚠️ Scope Violations Detected\n\nThe following files are outside their task\'s assigned scope:\n\n';
            for (const v of violations) {
              body += `### ${v.task}\n`;
              for (const f of v.files) {
                body += `- \`${f}\`\n`;
              }
              body += '\n';
            }
            body += 'Please review and ensure changes stay within assigned scope.';

            github.rest.issues.createComment({
              issue_number: context.issue.number,
              owner: context.repo.owner,
              repo: context.repo.repo,
              body: body,
            });

      - name: Fail on violations
        if: steps.check.outputs.violations != '[]'
        run: |
          echo "Scope violations detected. Check PR comment for details."
          exit 1
